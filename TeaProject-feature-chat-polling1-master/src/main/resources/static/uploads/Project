🍵 TeaProject (茶叶溯源销售与文化展示系统)
├── 📄 pom.xml                             # 📦 Maven 依赖配置 (声明了 Spring Boot、MyBatis-Plus 等所需工具)
├── 📄 _localhost-...-tea_db.sql           # 🗄️ 数据库初始化脚本 (包含建表语句和测试数据，部署必运行)
├── 📄 README.md                           # 📖 项目说明文档 (技术栈、部署指南)
│
├── 📂 src/main/java/com/tea/trace/        # ☕ 后端 Java 核心代码区
│   │
│   ├── 🚀 TeaTraceSystemApplication.java  # 【程序入口】项目启动类 (包含 main 方法，一键启动整个系统)
│   │
│   ├── 📂 controller/                     # 🌐 控制层 / API 接口 (前台接待员：接收前端请求)
│   │   ├── AuthController.java            # 处理登录、注册、图形验证码生成
│   │   ├── TeaController.java             # 处理商品列表、溯源查询、创建订单、沙箱支付扣款
│   │   └── ... (Admin/Order/File 等)      # 后台管理、订单等其他接口
│   │
│   ├── 📂 service/                        # 🧠 业务逻辑层 (大脑：处理复杂计算和业务规则)
│   │   ├── TeaService.java                # 业务接口定义 (指明能干什么)
│   │   └── 📂 impl/
│   │       └── TeaServiceImpl.java        # 具体业务逻辑的实现代码
│   │
│   ├── 📂 mapper/                         # 🗄️ 数据访问层 (数据库翻译官：和 MySQL 交互)
│   │   ├── UserMapper.java                # 继承 BaseMapper，自动拥有用户表的增删改查能力
│   │   ├── TeaMapper.java                 # 自动拥有茶叶表的增删改查能力
│   │   └── OrderMapper.java               # 自动拥有订单表的增删改查能力
│   │
│   └── 📂 entity/                         # 📦 实体类层 (数据的搬运箱：与数据库表一一对应)
│       ├── TeaUser.java                   # 用户表实体 (账号、密码、余额、角色)
│       ├── TeaProduct.java                # 茶叶商品实体 (名称、价格、溯源码、产地等)
│       ├── TeaOrder.java                  # 订单实体
│       └── TeaCulture.java                # 茶文化资讯实体
│
├── 📂 src/main/resources/                 # ⚙️ 配置文件与前端资源区
│   │
│   ├── 📄 application.yaml                # 🔧 核心配置文件 (数据库账号密码、端口号 8080 等都在这里改)
│   │
│   └── 📂 static/                         # 🎨 前端 Vue 页面及静态资源 (不用编译，直接运行)
│       ├── 📄 index.html                  # 首页 (商品展示、溯源档案弹窗、沙箱支付模拟)
│       ├── 📄 login.html                  # 登录与注册页面
│       ├── 📄 profile.html                # 个人中心 (根据 ADMIN 和 USER 角色展示不同面板)
│       ├── 📄 culture.html                # 茶文化科普页
│       └── 📂 uploads/                    # 🖼️ 图片上传与存储目录 (包含默认测试图，迁移时务必保留)
│
└── 📂 src/test/                           # 🧪 单元测试目录
    └── 📂 java/com/tea/trace/
        └── 📄 TraceApplicationTests.java  # 测试类